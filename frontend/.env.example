# ═══════════════════════════════════════════════════════════════════════
# AI Meeting & Workforce Platform — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════

# ── Application mode ─────────────────────────────────────────────────
# NEXT_PUBLIC_APP_MODE is for client-side display only (mock | production)
# DATA_PROVIDER controls which backend data source to use (mock | mongodb)
# DATA_PROVIDER is server-only and must NOT use the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_APP_MODE=mock
DATA_PROVIDER=mock

# Voice signaling server for WebRTC. Local default is http://localhost:3001.
# When sharing the app through a public tunnel, expose port 3001 too and set this
# to that public URL, for example https://your-tunnel-3001.example.com.
NEXT_PUBLIC_SIGNALING_URL=
NEXT_PUBLIC_VOICE_SERVER_URL=
NEXT_PUBLIC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:global.stun.twilio.com:3478
# Comma-separated list of TURN URLs. Each may include ?transport=udp|tcp.
# Examples:
#   turn:your-turn.com:3478?transport=udp,turn:your-turn.com:3478?transport=tcp
#   turns:your-turn.com:5349?transport=tcp
NEXT_PUBLIC_TURN_URLS=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
# Set to "true" to force all WebRTC media through TURN relay (for testing).
# Do not enable in production unless you understand the bandwidth cost.
NEXT_PUBLIC_FORCE_TURN=false
NEXT_PUBLIC_ENABLE_VOICE_DEBUG=false

# ── Client-side cost limits (informational — matched with costConstants.js) ─
# These are checked client-side before making expensive requests.
# Real enforcement happens server-side.
NEXT_PUBLIC_MAX_AI_AUDIO_SIZE_MB=50
NEXT_PUBLIC_WARNING_AI_AUDIO_SIZE_MB=35
NEXT_PUBLIC_MAX_TRANSCRIPT_CHARS=30000
NEXT_PUBLIC_AI_DAILY_RUN_LIMIT=3
NEXT_PUBLIC_MAX_JOB_CONCURRENCY=1
NEXT_PUBLIC_MAX_VOICE_RECORDINGS_PER_DAY=5

# ── AI estimation (client-side display only) ─────────────────────────
NEXT_PUBLIC_AI_COST_CENTS_PER_RUN=15

# ── TURN (server-side, preferred over NEXT_PUBLIC_TURN_URLS) ──────────
# When set, `/api/voice/ice-servers` returns these to the client.
# This is safer than NEXT_PUBLIC_TURN_URLS which is bundled in the client.
# For dev, you can set NEXT_PUBLIC_TURN_URLS instead (see above).
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
FORCE_TURN=false

# ═══════════════════════════════════════════════════════════════════════
# Server-only — DO NOT expose to frontend bundle
# ═══════════════════════════════════════════════════════════════════════

# ── AWS Region ───────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1

# ── S3 Storage ───────────────────────────────────────────────────────
# Bucket for uploaded meeting audio/transcript files
S3_MEETING_BUCKET=ai-meeting-platform-meetings
# Bucket for voice recording files
S3_RECORDING_BUCKET=ai-meeting-platform-recordings
# Bucket for Transcribe job output
TRANSCRIBE_OUTPUT_BUCKET=ai-meeting-platform-transcribe-output
# S3 lifecycle: auto-delete temp files after N days
S3_TEMP_FILE_RETENTION_DAYS=3
S3_FAILED_UPLOAD_RETENTION_DAYS=7
S3_RAW_AUDIO_RETENTION_DAYS=30

# ── SQS (async processing queue) ─────────────────────────────────────
SQS_MEETING_PROCESSING_QUEUE_URL=
SQS_VOICE_PROCESSING_QUEUE_URL=

# ── EventBridge ──────────────────────────────────────────────────────
EVENTBRIDGE_BUS_NAME=ai-meeting-platform-bus

# ── AI Processing ────────────────────────────────────────────────────
# Provider: openai | bedrock
AI_PROVIDER=openai
OPENAI_API_KEY=
# Daily run limits (server-side enforcement)
AI_DAILY_RUN_LIMIT=3
MAX_JOB_CONCURRENCY=1
# Transcribe job timeout (minutes)
TRANSCRIBE_JOB_TIMEOUT_MINUTES=60

# ── Authentication —──────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=24h
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# ── Observability ────────────────────────────────────────────────────
LOG_LEVEL=info
CLOUDWATCH_LOG_GROUP=ai-meeting-platform
