# ─── App Mode ──────────────────────────────────────────
# mock   = localStorage + WorkspaceContext (default, no backend needed)
# api    = Next.js API routes (pages/api/*)
# cloud  = API Gateway + Cognito (production AWS deployment)
NEXT_PUBLIC_APP_MODE=mock
NEXT_PUBLIC_API_BASE_URL=/api

# Voice signaling
# Leave blank for local development; the app falls back to http://localhost:3001.
NEXT_PUBLIC_SIGNALING_URL=
NEXT_PUBLIC_VOICE_SERVER_URL=

# WebRTC ICE. STUN is safe to expose. Prefer server-side TURN vars for real TURN credentials.
NEXT_PUBLIC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:global.stun.twilio.com:3478
NEXT_PUBLIC_TURN_URLS=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
NEXT_PUBLIC_FORCE_TURN=false
NEXT_PUBLIC_ENABLE_VOICE_DEBUG=false

# Client-side cost display/guardrails. Server-side APIs must enforce real limits.
NEXT_PUBLIC_MAX_AI_AUDIO_SIZE_MB=50
NEXT_PUBLIC_WARNING_AI_AUDIO_SIZE_MB=35
NEXT_PUBLIC_MAX_TRANSCRIPT_CHARS=30000
NEXT_PUBLIC_AI_DAILY_RUN_LIMIT=3
NEXT_PUBLIC_MAX_JOB_CONCURRENCY=1
NEXT_PUBLIC_MAX_VOICE_RECORDINGS_PER_DAY=5
NEXT_PUBLIC_AI_COST_CENTS_PER_RUN=15
NEXT_PUBLIC_API_GATEWAY_URL=
NEXT_PUBLIC_ENABLE_CLOUD_AUTH=false

# Server-only values used by Next.js API routes. Never prefix secrets with NEXT_PUBLIC_.
DATA_PROVIDER=mock
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
FORCE_TURN=false
AWS_REGION=ap-southeast-1
S3_MEETING_BUCKET=
S3_RECORDING_BUCKET=
TRANSCRIBE_OUTPUT_BUCKET=
BEDROCK_MODEL_ID=
OPENAI_API_KEY=
JWT_SECRET=
JWT_EXPIRES_IN=24h
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
